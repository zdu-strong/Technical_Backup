{
  "name": "my-app",
  "version": "0.1.0",
  "scripts": {
    "start": "npm config set registry https://registry.npmmirror.com && npm config set disturl https://npmmirror.com/mirrors/node && npm install -g typescript@4.6.3 @types/node@17.0.23 ts-node@10.7.0 cross-env@7.0.3 && cross-env TS_NODE_SKIP_PROJECT=true ts-node bin/electron_start.ts",
    "pack": "npm config set registry https://registry.npmmirror.com && npm config set disturl https://npmmirror.com/mirrors/node && npm install -g typescript@4.6.3 @types/node@17.0.23 ts-node@10.7.0 cross-env@7.0.3 && cross-env TS_NODE_SKIP_PROJECT=true ts-node bin/electron_pack.ts",
    "make": "npm config set registry https://registry.npmmirror.com && npm config set disturl https://npmmirror.com/mirrors/node && npm install -g typescript@4.6.3 @types/node@17.0.23 ts-node@10.7.0 cross-env@7.0.3 && cross-env TS_NODE_SKIP_PROJECT=true ts-node bin/electron_make.ts"
  },
  "main": "./dist/index.js",
  "private": true,
  "homepage": ".",
  "build": {
    "extends": null,
    "files": [
      "dist",
      "public",
      "build"
    ],
    "directories": {
      "output": "output"
    },
    "appId": "com.electron.electron",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "deleteAppDataOnUninstall": true,
      "guid": "b5a96e2b-5f4f-4a67-b77a-2c9d7c947242",
      "runAfterFinish": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": {
      "smartUnpack": true
    },
    "asarUnpack": [
      "public",
      "build"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "import/no-anonymous-default-export": [
        "off",
        {
          "allowArrowFunction": true
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      "last 1 chrome version"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "devDependencies": {
    "@emotion/react": "11.9.0",
    "@emotion/styled": "11.8.1",
    "@fontsource/roboto": "4.5.7",
    "@mui/icons-material": "5.8.0",
    "@mui/lab": "5.0.0-alpha.74",
    "@mui/material": "5.8.1",
    "@mui/x-date-pickers": "5.0.0-alpha.2",
    "@types/node": "17.0.36",
    "@types/node-os-utils": "1.2.0",
    "@types/qs": "6.9.7",
    "@types/react": "17.0.44",
    "@types/react-dom": "18.0.0",
    "@types/react-router-dom": "5.3.3",
    "@types/uuid": "8.3.4",
    "autoprefixer": "10.4.7",
    "date-fns": "2.28.0",
    "electron": "19.0.1",
    "electron-builder": "23.0.3",
    "get-port": "5.1.1",
    "mobx-react-use-autorun": "2.0.11",
    "postcss": "8.4.14",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-git-info": "2.0.1",
    "react-intl": "5.24.8",
    "react-router-dom": "6.3.0",
    "react-scripts": "5.0.1",
    "react-use": "17.4.0",
    "react-use-websocket": "3.0.0",
    "tailwindcss": "3.0.24",
    "typescript": "4.7.2",
    "typestyle": "2.3.0",
    "wait-on": "6.0.1",
    "web-vitals": "2.1.4",
    "windows-locale": "1.1.2"
  },
  "dependencies": {
    "@electron/remote": "2.0.8",
    "axios": "0.27.2",
    "electron-log": "4.4.7",
    "electron-store": "8.0.1",
    "execa": "5.1.1",
    "json-date-parser": "1.0.1",
    "linq": "3.2.4",
    "node-os-utils": "1.3.6",
    "qs": "6.10.3",
    "stream-to-string": "1.2.0",
    "tree-kill": "1.2.2",
    "uuid": "8.3.2"
  }
}
