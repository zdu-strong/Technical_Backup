    "@mui/material": "5.8.1",
    "@mui/x-date-pickers": "5.0.0-alpha.2",
    "@types/node": "17.0.36",
    "@types/qs": "6.9.7",
    "@types/react": "17.0.44",
    "@types/react-dom": "18.0.0",
    "@types/react-router-dom": "5.3.3",
    "@types/react-window": "1.8.5",
    "@types/uuid": "8.3.4",
    "autoprefixer": "10.4.7",
    "axios": "0.27.2",
